# ─── ChargeFlow Agent — root env template ───────────────────────────────
# Copy to `.env` for local dev:  cp .env.example .env
# These values are read by the server (server/index.js, server/services/llm.js).

# Your Anthropic API key. If omitted, the agent runs in MOCK_MODE automatically
# so the full UI + tool-orchestration demo still works without a key.
ANTHROPIC_API_KEY=

# Claude model to use. Defaults to the latest Sonnet if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Force mock responses even when a key is present (useful for offline demos).
# MOCK_MODE=true

# Backend port (Render injects its own PORT in production).
PORT=3001

# Allowed browser origin(s) for CORS, comma-separated.
# Local dev uses the Vite dev server; add your deployed frontend URL in prod.
CLIENT_ORIGIN=http://localhost:5173

# Optional rate-limit tuning for the public /api/chat endpoint.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=20

# Amap (高德) Web Service key — enables REAL nearby charging-station search via
# POI around-search. If unset, station search falls back to bundled mock data.
# Get one at https://lbs.amap.com (应用管理 → 创建应用 → 服务平台「Web服务」).
AMAP_WEB_KEY=
