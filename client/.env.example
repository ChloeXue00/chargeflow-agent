# ─── ChargeFlow Agent — client env template ─────────────────────────────
# Copy to `client/.env` (or set in Vercel project settings).

# Base URL of the backend API.
# Local dev: leave unset (defaults to http://localhost:3001/api).
# Full-stack Vercel deploy: leave unset — the client calls same-origin /api.
# VITE_API_BASE=http://localhost:3001/api

# Amap (高德) JS API — enables the interactive map (vehicle + station markers).
# Create a "Web端(JS API)" key at https://lbs.amap.com; it comes with a
# security code (安全密钥). If unset, the map simply doesn't render (UI unchanged).
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY=
